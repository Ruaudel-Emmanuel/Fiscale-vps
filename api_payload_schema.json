{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rennesdev.fr/schema/invoice-payload-v2.json",
  "title": "InvoicePayloadV2",
  "type": "object",
  "required": ["invoice", "seller", "buyer", "lines"],
  "properties": {
    "invoice": {
      "type": "object",
      "required": ["number", "issue_date", "currency", "operation_nature"],
      "properties": {
        "number": { "type": "string", "minLength": 1 },
        "issue_date": { "type": "string", "format": "date" },
        "supply_date": { "type": "string", "format": "date" },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$",
          "default": "EUR"
        },
        "operation_nature": {
          "type": "string",
          "enum": ["goods", "services", "mixed"]
        },
        "tva_on_debits_option": { "type": "boolean", "default": false },
        "payment_terms": { "type": "string" },
        "due_date": { "type": "string", "format": "date" }
      },
      "additionalProperties": false
    },

    "seller": {
      "type": "object",
      "required": ["name", "siren", "address"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "siren": {
          "type": "string",
          "pattern": "^[0-9]{9}$"
        },
        "siret": {
          "type": "string",
          "pattern": "^[0-9]{14}$"
        },
        "vat_number": { "type": "string" },
        "naf_code": { "type": "string" },
        "legal_form": { "type": "string" },
        "share_capital": { "type": ["number", "null"] },
        "rcs_city": { "type": ["string", "null"] },
        "address": {
          "type": "object",
          "required": ["line1", "postal_code", "city", "country_code"],
          "properties": {
            "line1": { "type": "string", "minLength": 1 },
            "line2": { "type": ["string", "null"] },
            "postal_code": { "type": "string", "minLength": 1 },
            "city": { "type": "string", "minLength": 1 },
            "country_code": {
              "type": "string",
              "pattern": "^[A-Z]{2}$",
              "default": "FR"
            }
          },
          "additionalProperties": false
        },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "website": { "type": "string", "format": "uri" }
      },
      "additionalProperties": false
    },

    "buyer": {
      "type": "object",
      "required": ["name", "siren", "address_billing"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "siren": {
          "type": "string",
          "pattern": "^[0-9]{9}$"
        },
        "siret": {
          "type": "string",
          "pattern": "^[0-9]{14}$"
        },
        "vat_number": { "type": "string" },
        "address_billing": {
          "type": "object",
          "required": ["line1", "postal_code", "city", "country_code"],
          "properties": {
            "line1": { "type": "string", "minLength": 1 },
            "line2": { "type": ["string", "null"] },
            "postal_code": { "type": "string", "minLength": 1 },
            "city": { "type": "string", "minLength": 1 },
            "country_code": {
              "type": "string",
              "pattern": "^[A-Z]{2}$",
              "default": "FR"
            }
          },
          "additionalProperties": false
        },
        "address_shipping": {
          "type": "object",
          "required": ["line1", "postal_code", "city", "country_code"],
          "properties": {
            "line1": { "type": "string", "minLength": 1 },
            "line2": { "type": ["string", "null"] },
            "postal_code": { "type": "string", "minLength": 1 },
            "city": { "type": "string", "minLength": 1 },
            "country_code": {
              "type": "string",
              "pattern": "^[A-Z]{2}$",
              "default": "FR"
            }
          },
          "additionalProperties": false
        },
        "email": { "type": "string", "format": "email" }
      },
      "additionalProperties": false
    },

    "lines": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "line_number",
          "description",
          "quantity",
          "unit_price_ht",
          "tva_rate"
        ],
        "properties": {
          "line_number": { "type": "integer", "minimum": 1 },
          "description": { "type": "string", "minLength": 1 },
          "quantity": { "type": "number", "exclusiveMinimum": 0 },
          "unit": { "type": "string" },
          "unit_price_ht": { "type": "number" },
          "tva_rate": { "type": "number" },
          "discount_rate": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "default": 0
          }
        },
        "additionalProperties": false
      }
    },

    "totals": {
      "type": "object",
      "properties": {
        "total_ht": { "type": "number" },
        "total_discount": { "type": "number" },
        "total_tva": { "type": "number" },
        "total_ttc": { "type": "number" }
      },
      "additionalProperties": false
    },

    "meta": {
      "type": "object",
      "properties": {
        "language": {
          "type": "string",
          "default": "fr"
        },
        "profile": {
          "type": "string",
          "enum": ["BASIC", "EN16931"],
          "default": "BASIC"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "generation_tool": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}